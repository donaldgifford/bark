# bark — local development environment variables
# Copy this file to .env.local and populate with your values.
# Never commit .env.local — it is gitignored.

# =============================================================================
# Infrastructure
# =============================================================================

# S3 bucket name for package storage
BARK_S3_BUCKET=homebrew-bottles

# LocalStack endpoint — set this to override the real AWS endpoint in local dev.
# Leave unset or empty in production.
BARK_S3_ENDPOINT=http://localhost:4566

# AWS region
AWS_DEFAULT_REGION=us-east-1

# AWS credentials for LocalStack (any non-empty value works)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# =============================================================================
# API Server
# =============================================================================

# Address the API server listens on
BARK_API_ADDR=:8080

# Database connection string (PostgreSQL)
BARK_DB_DSN=postgres://bark:bark@localhost:5432/bark?sslmode=disable

# Presigned URL TTL in minutes (default: 5)
BARK_PRESIGNED_URL_TTL_MINUTES=5

# =============================================================================
# Authentication (OIDC)
# =============================================================================

# OIDC provider issuer URL — used to discover JWKS endpoint
BARK_OIDC_ISSUER=https://your-org.okta.com/oauth2/default

# Expected audience claim in JWTs
BARK_OIDC_AUDIENCE=bark-api

# =============================================================================
# Pipeline
# =============================================================================

# Pipeline service token — presented by CI when calling the registration endpoint.
# Must be distinct from user JWTs.
BARK_PIPELINE_TOKEN=change-me-in-production

# Vulnerability scanner to use: "grype" (default) or "wiz" (see IMPL-0002)
BARK_SCANNER=grype

# Severity threshold at which grype fails the scan (critical, high, medium, low)
GRYPE_FAIL_ON_SEVERITY=critical

# Wiz provider — only required when BARK_SCANNER=wiz
# WIZCLI_TOKEN=
# WIZCLI_API_URL=https://api.wiz.io
# WIZCLI_POLICY_NAME=

# Allowed internal bottle origins (comma-separated URL prefixes)
BARK_INTERNAL_ORIGIN_ALLOWLIST=https://github.com/donaldgifford/

# =============================================================================
# Signing
# =============================================================================

# Path to the cosign private key (pipeline only — never exposed to API or CLI)
BARK_COSIGN_KEY_PATH=infra/keys/cosign-dev.key

# =============================================================================
# CLI (pkgtool)
# =============================================================================

# API base URL used by the CLI
BARK_API_URL=http://localhost:8080

# OIDC client ID for the device flow
BARK_OIDC_CLIENT_ID=bark-cli

# =============================================================================
# Notifications (Phase 6+)
# =============================================================================

# Slack webhook URL for approval notifications (leave empty to disable)
# BARK_SLACK_WEBHOOK_URL=
